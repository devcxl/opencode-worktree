{
  "name": "@devcxl/opencode-worktree",
  "version": "0.1.1",
  "description": "OpenCode Worktree Plugin - Creates isolated git worktrees for AI development sessions",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devcxl/opencode-worktree.git"
  },
  "homepage": "https://github.com/devcxl/opencode-worktree",
  "bugs": {
    "url": "https://github.com/devcxl/opencode-worktree/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "git-worktree",
    "ai-coding-agent"
  ],
  "type": "module",
  "main": "./dist/server.js",
  "oc-plugin": [
    "server"
  ],
  "exports": {
    "./server": {
      "import": "./dist/server.js",
      "config": {}
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.7",
    "@opencode-ai/sdk": "^1.3.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "jsonc-parser": "^3.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  }
}
